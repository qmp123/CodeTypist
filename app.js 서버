const express = require("express");
const cors = require("cors");
const app = express();

const { sendSuccessResponse, sendErrorResponse } = require("./utils/response-utils");
const practiceRouter = require("./routes/practice-route");
const miniRouter = require("./routes/mini-route");

const defaultPort = 3000;
const serverPort = Number.isFinite(Number(process.env.PORT))
  ? Number(process.env.PORT)
  : defaultPort;

app.use(
  cors({
    origin: [
      "http://localhost:5173",
      "http://localhost:3000"
    ],
    methods: ["GET", "POST"],
  })
);

app.use(express.json({ limit: "256kb" }));

app.get("/api/health", (req, res) => {
  return sendSuccessResponse(res, { status: "ok", service: "codetypist" });
});

app.use("/api/practice", practiceRouter);
app.use("/api/mini", miniRouter);

app.use((req, res) => {
  return sendErrorResponse(res, 404, "api not found");
});

app.use((err, req, res, next) => {
  console.error(err);
  if (res.headersSent) return next(err);
  return sendErrorResponse(res, 500, "internal server error");
});

app.listen(serverPort, () => {
  console.log(`✅ Server running on port ${serverPort}`);
});
