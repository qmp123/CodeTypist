            "#include <stdio.h>",
            "typedef struct {",
            "    char name[20];",
            "    int score;",
            "} Student;"
          ],
          [
            "void swap(Student* a, Student* b) {",
            "    Student t = *a;",
            "    *a = *b;",
            "    *b = t;",
            "}"
          ],
          [
            "void sortByScore(Student arr[], int n) {",
            "    for (int i = 0; i < n - 1; i++) {",
            "        for (int j = i + 1; j < n; j++) {",
            "            if (arr[i].score < arr[j].score) swap(&arr[i], &arr[j]);",
            "        }"
          ],
          [
            "    }",
            "}",
            "int main() {",
            "    Student s[3] = {{\"Kim\", 70}, {\"Lee\", 95}, {\"Park\", 85}};",
            "    sortByScore(s, 3);"
          ],
          [
            "    for (int i = 0; i < 3; i++) printf(\"%s %d\\n\", s[i].name, s[i].score);",
